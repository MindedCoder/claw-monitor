{
  "port": 4180,
  "cookieName": "_auth_gw",
  "cookieMaxAgeSec": 604800,
  "secret": "替换成一个随机字符串",

  "// 默认身份提供商（未匹配到任何 tenant 时使用）": "",
  "authProvider": "password",
  "provider": {
    "password": "your-secret-password",
    "username": "admin"
  },

  "// 多租户配置（可选）：不同路径前缀使用不同的 IdP": "",
  "// 访问 /tenant-a/* 时用租户 A 的飞书应用认证": "",
  "// 访问 /tenant-b/* 时用租户 B 的微信认证": "",
  "// 未匹配的路径 fallback 到上面的默认 password 认证": "",
  "tenants": {
    "/tenant-a": {
      "authProvider": "feishu",
      "provider": {
        "appId": "飞书应用A的appId",
        "appSecret": "飞书应用A的appSecret",
        "allowedDepartments": []
      }
    },
    "/tenant-b": {
      "authProvider": "feishu",
      "provider": {
        "appId": "飞书应用B的appId",
        "appSecret": "飞书应用B的appSecret",
        "allowedDepartments": []
      }
    }
  }
}
