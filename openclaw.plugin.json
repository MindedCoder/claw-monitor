{
  "id": "infra-services",
  "name": "Infra Services",
  "description": "监控面板 + frpc 隧道 + 飞书处理中通知",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "properties": {
      "statusPageUrl": {
        "type": "string",
        "description": "监控面板公网地址",
        "default": ""
      },
      "frpc": {
        "type": "object",
        "properties": {
          "serverAddr": { "type": "string", "description": "frp 服务器地址" },
          "serverPort": { "type": "number", "default": 7000 },
          "remotePort": { "type": "number", "description": "远程映射端口" }
        }
      },
      "monitor": {
        "type": "object",
        "properties": {
          "port": { "type": "number", "default": 9001 }
        }
      }
    }
  }
}
